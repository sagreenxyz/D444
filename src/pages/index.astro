---
import '../styles/global.css';
import { requirements, topicSlug, slugify, link } from '../data/saunders.js';

const recommendation =
	'It is strongly recommended that you complete the Basic Skills course prior to taking the OA for Adult Health I.';

const saunders = requirements.find((r) => r.topics);
const totalQuestions = saunders.topics.reduce((sum, t) => sum + t.count, 0);
const totalDone = saunders.topics.reduce((sum, t) => sum + t.done, 0);
const overallPct = Math.round((totalDone / totalQuestions) * 100);
const pct = (t) => Math.round((t.done / t.count) * 100);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={link('/favicon.svg')} />
		<link rel="icon" href={link('/favicon.ico')} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>D444 Adult Health I — OA Prep Tracker</title>
		<meta
			name="description"
			content="Personal study tracker for the D444 Adult Health I OA approval requirements."
		/>
	</head>
	<body class="min-h-screen bg-slate-50 text-slate-800 antialiased">
		<header class="border-b border-slate-200 bg-white">
			<div class="mx-auto max-w-4xl px-6 py-8">
				<p class="text-sm font-semibold uppercase tracking-wide text-sky-700">
					D444 Adult Health I
				</p>
				<h1 class="mt-2 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
					OA Approval Prep Tracker
				</h1>
				<p class="mt-4 max-w-2xl text-slate-600">
					A personal study checklist for the four remaining requirements that need
					to be completed before OA approval.
				</p>
			</div>
		</header>

		<main class="mx-auto max-w-4xl px-6 py-12">
			<section
				class="rounded-2xl border border-amber-200 bg-amber-50 p-6"
				aria-label="Recommendation"
			>
				<h2 class="text-sm font-bold uppercase tracking-wide text-amber-700">
					Strongly Recommended
				</h2>
				<p class="mt-2 text-amber-900">{recommendation}</p>
			</section>

			<section class="mt-10 space-y-8" aria-label="Remaining requirements">
				<h2 class="text-2xl font-bold tracking-tight text-slate-900">
					4 Remaining Requirements
				</h2>

				{requirements.map((req) => (
					<article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
						<div class="flex items-start gap-4">
							<label class="flex items-center pt-1">
								<input
									type="checkbox"
									class="h-6 w-6 rounded border-slate-300 text-sky-600 focus:ring-sky-500"
									aria-label={`Mark requirement ${req.id} complete`}
								/>
							</label>
							<div class="flex-1">
								<div class="flex items-baseline gap-3">
									<span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-sky-100 text-sm font-bold text-sky-700">
										{req.id}
									</span>
									<h3 class="text-lg font-semibold text-slate-900">
										{req.title}
									</h3>
								</div>
								<p class="mt-3 leading-relaxed text-slate-700">{req.summary}</p>

								{req.link && (
									<a
										href={req.link.href}
										target="_blank"
										rel="noopener noreferrer"
										class="mt-4 inline-flex items-center gap-2 rounded-full bg-sky-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-sky-700"
									>
										{req.link.label}
									</a>
								)}

								{req.details && (
									<ul class="mt-4 space-y-2 border-l-2 border-slate-100 pl-4 text-slate-600">
										{req.details.map((d) => (
											<li class="leading-relaxed">{d}</li>
										))}
									</ul>
								)}

								{req.topics && (
									<div class="mt-5">
										<div class="flex flex-wrap items-center justify-between gap-3">
											<p class="font-medium text-slate-700">{req.quizIntro}</p>
											<span class="inline-flex items-center rounded-full bg-sky-100 px-3 py-1 text-sm font-semibold text-sky-700">
												{totalQuestions} questions total
											</span>
										</div>

										<div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-4">
											<div class="flex items-center justify-between text-sm font-semibold text-slate-700">
												<span>Overall progress</span>
												<span>{totalDone} / {totalQuestions} ({overallPct}%)</span>
											</div>
											<div class="mt-2 h-3 w-full overflow-hidden rounded-full bg-slate-200">
												<div
													class="h-3 rounded-full bg-sky-600 transition-all"
													style={`width: ${overallPct}%`}
												></div>
											</div>
										</div>

										<ul class="mt-4 space-y-4">
											{req.topics.map((t) => (
												<li class="rounded-lg bg-slate-50 px-4 py-3">
													<div class="flex items-start justify-between gap-4">
														<a href={link(`/topics/${topicSlug(t)}`)} class="leading-relaxed font-medium text-sky-700 hover:text-sky-800 hover:underline">{t.label}</a>
														<span class="mt-0.5 shrink-0 text-sm font-semibold text-slate-600">
															{t.done} / {t.count}
														</span>
													</div>
													<div class="mt-2 flex items-center gap-3">
														<div class="h-2 w-full overflow-hidden rounded-full bg-slate-200">
															<div
																class="h-2 rounded-full bg-sky-500 transition-all"
																style={`width: ${pct(t)}%`}
															></div>
														</div>
														<span class="w-10 shrink-0 text-right text-xs font-medium text-slate-500">
															{pct(t)}%
														</span>
													</div>

													{t.breakdown && (
														<details class="mt-3">
															<summary class="cursor-pointer text-sm font-semibold text-sky-700 hover:text-sky-800">
																Subtopic breakdown ({t.breakdown.length} groups)
															</summary>
													{t.breakdownNote && (
														<p class="mt-3 rounded-md border border-amber-200 bg-amber-50 px-3 py-2 text-xs leading-relaxed text-amber-800">{t.breakdownNote}</p>
													)}
															<ul class="mt-3 space-y-3">
																{t.breakdown.map((b) => (
																	<li class="rounded-md border border-slate-200 bg-white p-3">
																		<div class="flex items-center justify-between gap-3">
																			<a href={link(`/topics/${topicSlug(t)}/${slugify(b.name)}`)} class="font-semibold text-sky-700 hover:text-sky-800 hover:underline">{b.name}</a>
																			<span class="shrink-0 rounded-full bg-sky-100 px-2 py-0.5 text-xs font-semibold text-sky-700">
																				{t.breakdownApprox ? `~${b.count}` : b.count}
																			</span>
																		</div>
																		{b.questions && (<p class="mt-1 text-xs font-medium text-slate-500">{b.questions}</p>)}
																		{b.notes && (<p class="mt-1 text-sm leading-relaxed text-slate-600">{b.notes}</p>)}
																	</li>
																))}
															</ul>
														</details>
													)}
												</li>
											))}
										</ul>
										<p class="mt-4 rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-medium text-slate-600">
											{req.excluded}
										</p>
									</div>
								)}
							</div>
						</div>
					</article>
				))}
			</section>

			<section class="mt-10 rounded-2xl border border-sky-200 bg-sky-50 p-6">
				<p class="leading-relaxed text-sky-900">
					Once these items are completed, the instructor will be able to approve
					the OA.
				</p>
			</section>
		</main>

		<footer class="border-t border-slate-200 bg-white">
			<div class="mx-auto max-w-4xl px-6 py-6 text-sm text-slate-500">
				<p>D444 Adult Health I — Personal OA prep tracker.</p>
			</div>
		</footer>
	</body>
</html>

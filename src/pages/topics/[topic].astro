---
import '../../styles/global.css';
import { saundersTopics, topicSlug, topicName, slugify, link } from '../../data/saunders.js';

export function getStaticPaths() {
	return saundersTopics.map((t) => ({ params: { topic: topicSlug(t) }, props: { topic: t } }));
}

const { topic } = Astro.props;
const done = topic.done ?? 0;
const pct = topic.count ? Math.round((done / topic.count) * 100) : 0;
const subtopics = topic.breakdown ?? [];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={link('/favicon.svg')} />
		<link rel="icon" href={link('/favicon.ico')} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{topicName(topic)} — D444 Adult Health I</title>
	</head>
	<body class="min-h-screen bg-slate-50 text-slate-800 antialiased">
		<header class="border-b border-slate-200 bg-white">
			<div class="mx-auto max-w-4xl px-6 py-8">
				<a href={link('/')} class="text-sm font-semibold text-sky-700 hover:text-sky-800">&larr; Back to tracker</a>
				<h1 class="mt-3 text-2xl font-extrabold tracking-tight text-slate-900 sm:text-3xl">{topic.label}</h1>
				<p class="mt-3 text-slate-600">
					{topic.count} questions{topic.breakdownApprox ? ' (approximate groupings)' : ''}
				</p>
			</div>
		</header>

		<main class="mx-auto max-w-4xl px-6 py-10">
			<div class="rounded-xl border border-slate-200 bg-white p-5">
				<div class="flex items-center justify-between text-sm font-semibold text-slate-700">
					<span>Progress</span>
					<span>{done} / {topic.count} ({pct}%)</span>
				</div>
				<div class="mt-2 h-3 w-full overflow-hidden rounded-full bg-slate-200">
					<div class="h-3 rounded-full bg-sky-600" style={`width: ${pct}%`}></div>
				</div>
			</div>

			{topic.breakdownNote && (
				<p class="mt-6 rounded-md border border-amber-200 bg-amber-50 px-4 py-3 text-sm leading-relaxed text-amber-800">
					{topic.breakdownNote}
				</p>
			)}

			<h2 class="mt-8 text-lg font-bold text-slate-900">Subtopics ({subtopics.length})</h2>
			<ul class="mt-4 space-y-3">
				{subtopics.map((b) => (
					<li>
						<a
							href={link(`/topics/${topicSlug(topic)}/${slugify(b.name)}`)}
							class="flex items-center justify-between gap-4 rounded-lg border border-slate-200 bg-white px-4 py-3 transition hover:border-sky-400 hover:shadow-sm"
						>
							<span class="font-medium text-slate-800">{b.name}</span>
							<span class="shrink-0 rounded-full bg-sky-100 px-2.5 py-0.5 text-xs font-semibold text-sky-700">
								{topic.breakdownApprox ? `~${b.count}` : b.count}
							</span>
						</a>
					</li>
				))}
			</ul>
		</main>
	</body>
</html>

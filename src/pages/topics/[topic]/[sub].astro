---
import '../../../styles/global.css';
import { saundersTopics, topicSlug, topicName, slugify, link } from '../../../data/saunders.js';

export function getStaticPaths() {
	const paths = [];
	for (const t of saundersTopics) {
		for (const b of t.breakdown ?? []) {
			paths.push({ params: { topic: topicSlug(t), sub: slugify(b.name) }, props: { topic: t, sub: b } });
		}
	}
	return paths;
}

const { topic, sub } = Astro.props;
const count = topic.breakdownApprox ? `~${sub.count}` : sub.count;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={link('/favicon.svg')} />
		<link rel="icon" href={link('/favicon.ico')} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{sub.name} — {topicName(topic)} — D444</title>
	</head>
	<body class="min-h-screen bg-slate-50 text-slate-800 antialiased">
		<header class="border-b border-slate-200 bg-white">
			<div class="mx-auto max-w-3xl px-6 py-8">
				<nav class="flex flex-wrap items-center gap-2 text-sm font-semibold text-sky-700">
					<a href={link('/')} class="hover:text-sky-800">Tracker</a>
					<span class="text-slate-400">/</span>
					<a href={link(`/topics/${topicSlug(topic)}`)} class="hover:text-sky-800">{topicName(topic)}</a>
				</nav>
				<h1 class="mt-3 text-2xl font-extrabold tracking-tight text-slate-900 sm:text-3xl">{sub.name}</h1>
				<p class="mt-3 inline-flex items-center rounded-full bg-sky-100 px-3 py-1 text-sm font-semibold text-sky-700">
					{count} question{sub.count === 1 ? '' : 's'}
				</p>
			</div>
		</header>

		<main class="mx-auto max-w-3xl space-y-6 px-6 py-10">
			{sub.questions && (
				<section class="rounded-xl border border-slate-200 bg-white p-5">
					<h2 class="text-sm font-bold uppercase tracking-wide text-slate-500">Question numbers</h2>
					<p class="mt-2 leading-relaxed text-slate-700">{sub.questions}</p>
				</section>
			)}

			{sub.notes && (
				<section class="rounded-xl border border-slate-200 bg-white p-5">
					<h2 class="text-sm font-bold uppercase tracking-wide text-slate-500">Coverage</h2>
					<p class="mt-2 leading-relaxed text-slate-700">{sub.notes}</p>
				</section>
			)}

			<a href={link(`/topics/${topicSlug(topic)}`)} class="inline-flex text-sm font-semibold text-sky-700 hover:text-sky-800">
				&larr; Back to {topicName(topic)}
			</a>
		</main>
	</body>
</html>
